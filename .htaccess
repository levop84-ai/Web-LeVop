# ============================================================
# Lenka Vopařilová – .htaccess konfigurace
# POZOR: Přesměrování (redirect) se řeší na úrovni hostingu,
#         zde je POUZE bezpečnost, výkon a chybové stránky.
# ============================================================

# --- Chybové stránky ---
ErrorDocument 404 /404.html

# --- Bezpečnostní HTTP hlavičky ---
<IfModule mod_headers.c>
    # Zabrání prohlížeči odhadovat MIME typ
    Header always set X-Content-Type-Options "nosniff"

    # Ochrana před clickjackingem
    Header always set X-Frame-Options "SAMEORIGIN"

    # Zastaralá ochrana před XSS (stará klienti)
    Header always set X-XSS-Protection "1; mode=block"

    # Politika odkazovače
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Omezení přístupu k hardwaru
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; \
        script-src 'self' https://cdnjs.cloudflare.com; \
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; \
        font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; \
        img-src 'self' data:; \
        connect-src 'self' https://formspree.io; \
        frame-src 'none'; \
        object-src 'none'; \
        base-uri 'self';"

    # HSTS – HTTPS povinné (povolte až po nasazení HTTPS certifikátu)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# --- Gzip komprese ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# --- Cachování v prohlížeči ---
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML – krátká cache
    ExpiresByType text/html "access plus 1 hour"

    # CSS a JS – střednědobá cache (verzování změnami v URL)
    ExpiresByType text/css              "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"

    # Obrázky
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/png  "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/avif "access plus 6 months"

    # Fonty
    ExpiresByType font/woff  "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# --- Blokovat přístup ke skrytým souborům ---
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- Zakázat výpis adresáře ---
Options -Indexes
